@using BookSwap.Data.Models.Common
@model IEnumerable<BookSwap.Web.ViewModels.SwapRequests.SwapRequestOwnerViewModel>

@{
    ViewData["Title"] = "Swap Requests for My Books";
}

<h2 class="fw-bold mb-4">📩 Swap Requests for My Books</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">
        @TempData["ErrorMessage"]
    </div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">
        No swap requests yet.
    </div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Book</th>
                <th>Requested By</th>
                <th>Date</th>
                <th>Status</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var req in Model)
            {
                <tr>
                    <td>@req.BookTitle</td>

                    <td>@req.ApplicantUsername</td>

                    <td>@req.CreatedOn.ToShortDateString()</td>

                    <td>

                        @if (req.Status == StatusType.Pending)
                        {
                            <span class="badge bg-warning text-dark me-2">Pending</span>

                            <form asp-controller="SwapRequest" asp-action="Approve" method="post" style="display:inline;">
                                <input type="hidden" name="id" value="@req.Id" />
                                <button type="submit" class="btn btn-success btn-sm">
                                    Approve
                                </button>
                            </form>

                            <form asp-controller="SwapRequest" asp-action="Reject" method="post" style="display:inline;">
                                <input type="hidden" name="id" value="@req.Id" />
                                <button type="submit" class="btn btn-danger btn-sm">
                                    Reject
                                </button>
                            </form>
                        }
                        else if (req.Status == StatusType.Approved)
                        {
                            <span class="badge bg-success">Approved</span>
                        }
                        else if (req.Status == StatusType.Rejected)
                        {
                            <span class="badge bg-danger">Rejected</span>
                        }

                    </td>
                </tr>
            }
        </tbody>
    </table>
}